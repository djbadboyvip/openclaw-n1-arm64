# 运行环境（production / development）
NODE_ENV=production

# 时区
TZ=Asia/Shanghai

# OpenClaw 日志级别（trace, debug, info, warn, error）
OPENCLAW_LOG_LEVEL=info

# 调试模式（true/false）
OPENCLAW_DEBUG=false

# 映射到主机的端口
OPENCLAW_PORT=18789

# 代理配置（如果网络需要通过代理访问 Telegram API 等）
HTTP_PROXY=http://192.168.2.80:7890
HTTPS_PROXY=http://192.168.2.80:7890
NO_PROXY=localhost,127.0.0.1
